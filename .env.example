# Expo + Convex
EXPO_PUBLIC_CONVEX_URL=
EXPO_PUBLIC_CONVEX_SITE_URL=
EXPO_PUBLIC_EAS_PROJECT_ID=
INTERNAL_ADMIN_EMAILS=
EXPO_PUBLIC_AUTH_PROVIDER=clerk
EXPO_PUBLIC_APP_DOMAIN=join-queue.com
EXPO_PUBLIC_RAPYD_CHECKOUT_APP_RETURN_URL=queue://rapyd/checkout-return
EXPO_PUBLIC_RAPYD_APP_RETURN_URL=queue://rapyd/beneficiary-return
EXPO_PUBLIC_RAPYD_BENEFICIARY_RETURN_URL=https://your-convex-site.convex.site/rapyd/beneficiary-return-bridge
EXPO_PUBLIC_RAPYD_BENEFICIARY_COMPLETE_URL=https://your-convex-site.convex.site/rapyd/beneficiary-return-bridge?result=complete&target=queue%3A%2F%2Frapyd%2Fbeneficiary-return
EXPO_PUBLIC_RAPYD_BENEFICIARY_CANCEL_URL=https://your-convex-site.convex.site/rapyd/beneficiary-return-bridge?result=cancel&target=queue%3A%2F%2Frapyd%2Fbeneficiary-return

# Auth (Clerk)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=

# Auth (WorkOS/AuthKit)
EXPO_PUBLIC_WORKOS_CLIENT_ID=
WORKOS_API_KEY=

# Maps
EXPO_PUBLIC_PM_TILES_URL=
EXPO_PUBLIC_PM_TILES_MAX_ZOOM=11
# Optional fallback style URL (keep empty to avoid masking PMTiles issues)
EXPO_PUBLIC_BASEMAP_STYLE_URL=

# Optional (if using Google Places)
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# Calendar OAuth (Google Calendar)
# These same native Google OAuth client IDs are also reused for native account sign-in.
EXPO_PUBLIC_GOOGLE_CALENDAR_CLIENT_ID_IOS=
EXPO_PUBLIC_GOOGLE_CALENDAR_CLIENT_ID_ANDROID=
EXPO_PUBLIC_GOOGLE_CALENDAR_CLIENT_ID_WEB=
EXPO_PUBLIC_GOOGLE_CALENDAR_SERVER_CLIENT_ID=
# Optional: override OAuth redirect host for auth-session proxy / web flows
EXPO_PUBLIC_GOOGLE_CALENDAR_REDIRECT_URL=
# Optional (Convex action allow-list): comma-separated OAuth client IDs accepted by backend
GOOGLE_CALENDAR_CLIENT_IDS=
GOOGLE_CALENDAR_SERVER_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Theme + Tab behavior flags
EXPO_PUBLIC_THEME_GENERATED_ENABLED=1
EXPO_PUBLIC_THEME_ALIAS_STRICT_MODE=0
EXPO_PUBLIC_TABS_ANDROID_FLOATING_ENABLED=1
EXPO_PUBLIC_TABS_ANDROID_FLOATING_COMPACT_ONLY=0

# Payments / KYC (server-side only, do not expose in Expo public env)
UNIPAAS_API_BASE_URL=
UNIPAAS_API_KEY=
DIDIT_BASE_URL=https://verification.didit.me
DIDIT_API_KEY=
DIDIT_WORKFLOW_ID=
DIDIT_WEBHOOK_SECRET=
RAPYD_MODE=sandbox
# Use one of:
# - RAPYD_SANDBOX_BASE_URL=https://sandboxapi.rapyd.net
# - RAPYD_PROD_BASE_URL=https://api.rapyd.net
# Keep URL without query/hash; trailing slash is tolerated but unnecessary.
RAPYD_SANDBOX_BASE_URL=https://sandboxapi.rapyd.net
RAPYD_PROD_BASE_URL=https://api.rapyd.net
RAPYD_ACCESS_KEY=
RAPYD_SECRET_KEY=
RAPYD_WEBHOOK_SECRET=
RAPYD_COUNTRY=IL
# Checkout mode (defaults are environment-sensitive):
# - sandbox: defaults to "flexible" (card-capable) since IL sandbox lacks A2A pay-in rails
# - production: defaults to "a2a" (fail-closed bank-only)
# Override only if you need to test a specific mode explicitly:
# RAPYD_CHECKOUT_MODE=a2a
# Optional comma-separated allow-list. Leave empty to let Rapyd decide
# country-valid methods automatically.
RAPYD_PAYMENT_METHODS=
# Optional: override Israel sandbox bank payout default (defaults to il_general_bank).
# Only needed if you need a different bank payout method type in sandbox.
# RAPYD_DEFAULT_BANK_PAYOUT_METHOD_TYPE=il_general_bank
RAPYD_EWALLET=
RAPYD_COMPLETE_CHECKOUT_URL=https://your-convex-site.convex.site/rapyd/checkout-return-bridge
RAPYD_CANCEL_CHECKOUT_URL=https://your-convex-site.convex.site/rapyd/checkout-return-bridge
RAPYD_BENEFICIARY_COMPLETE_URL=https://your-convex-site.convex.site/rapyd/beneficiary-return-bridge?result=complete&target=queue%3A%2F%2Frapyd%2Fbeneficiary-return
RAPYD_BENEFICIARY_CANCEL_URL=https://your-convex-site.convex.site/rapyd/beneficiary-return-bridge?result=cancel&target=queue%3A%2F%2Frapyd%2Fbeneficiary-return
RAPYD_CHECKOUT_APP_RETURN_URL=queue://rapyd/checkout-return
RAPYD_APP_RETURN_URL=queue://rapyd/beneficiary-return
PAYMENTS_CURRENCY=ILS
QUICKFIT_PLATFORM_MARKUP_BPS=1500
PAYMENTS_ALLOWED_REDIRECT_PROTOCOLS=https:,queue:,exp:,exps:
PAYMENTS_ALLOWED_REDIRECT_HOSTS=

# Auth (Convex + Resend OTP)
# Use either RESEND_API_KEY or AUTH_RESEND_KEY
RESEND_API_KEY=
AUTH_RESEND_KEY=
# Must use a verified sender/domain for non-test recipients
AUTH_EMAIL_FROM=
# Dev-only: reroute all OTP emails to one inbox so you can test many accounts
AUTH_EMAIL_DEV_INBOX=
