# Expo + Convex
EXPO_PUBLIC_CONVEX_URL=
EXPO_PUBLIC_AUTH_PROVIDER=clerk

# Auth (Clerk)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=

# Auth (WorkOS/AuthKit)
EXPO_PUBLIC_WORKOS_CLIENT_ID=
WORKOS_API_KEY=

# Maps
EXPO_PUBLIC_PM_TILES_URL=
EXPO_PUBLIC_PM_TILES_MAX_ZOOM=11
# Optional fallback style URL (keep empty to avoid masking PMTiles issues)
EXPO_PUBLIC_BASEMAP_STYLE_URL=

# Optional (if using Google Places)
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# Theme + Tab behavior flags
EXPO_PUBLIC_THEME_GENERATED_ENABLED=1
EXPO_PUBLIC_THEME_ALIAS_STRICT_MODE=0
EXPO_PUBLIC_TABS_ANDROID_FLOATING_ENABLED=1
EXPO_PUBLIC_TABS_ANDROID_FLOATING_COMPACT_ONLY=0

# Payments / KYC (server-side only, do not expose in Expo public env)
UNIPAAS_API_BASE_URL=
UNIPAAS_API_KEY=
RAPYD_MODE=sandbox
# Use one of:
# - RAPYD_SANDBOX_BASE_URL=https://sandboxapi.rapyd.net
# - RAPYD_PROD_BASE_URL=https://api.rapyd.net
# Keep URL without query/hash; trailing slash is tolerated but unnecessary.
RAPYD_SANDBOX_BASE_URL=https://sandboxapi.rapyd.net
RAPYD_PROD_BASE_URL=https://api.rapyd.net
RAPYD_ACCESS_KEY=
RAPYD_SECRET_KEY=
RAPYD_WEBHOOK_SECRET=
RAPYD_COUNTRY=IL
RAPYD_PAYMENT_METHODS=il_card,apple_pay,google_pay
RAPYD_EWALLET=
RAPYD_COMPLETE_CHECKOUT_URL=https://example.com/rapyd/checkout-complete
RAPYD_CANCEL_CHECKOUT_URL=https://example.com/rapyd/checkout-cancel
PAYMENTS_CURRENCY=ILS
QUICKFIT_PLATFORM_MARKUP_BPS=1500
PAYMENTS_ALLOWED_REDIRECT_PROTOCOLS=https:,queue:,exp:,exps:
PAYMENTS_ALLOWED_REDIRECT_HOSTS=

# Auth (Convex + Resend OTP)
# Use either RESEND_API_KEY or AUTH_RESEND_KEY
RESEND_API_KEY=
AUTH_RESEND_KEY=
# Must use a verified sender/domain for non-test recipients
AUTH_EMAIL_FROM=
# Dev-only: reroute all OTP emails to one inbox so you can test many accounts
AUTH_EMAIL_DEV_INBOX=
