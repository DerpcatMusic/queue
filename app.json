{
  "expo": {
    "name": "queue",
    "slug": "queue",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "queue",
    "userInterfaceStyle": "automatic",
    "ios": {
      "userInterfaceStyle": "automatic",
      "supportsTablet": true
    },
    "android": {
      "package": "com.derpcat.queue",
      "userInterfaceStyle": "automatic",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false
    },
    "androidStatusBar": {
      "translucent": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "updates": {
      "checkAutomatically": "ON_ERROR_RECOVERY",
      "fallbackToCacheTimeout": 0
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-system-ui",
        {
          "userInterfaceStyle": "automatic"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-localization",
        {
          "supportedLocales": {
            "ios": [
              "en",
              "he"
            ],
            "android": [
              "en",
              "he"
            ]
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Queue to use your location to detect your service zone.",
          "isAndroidForegroundServiceEnabled": false
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow Queue to sync accepted sessions to your calendar.",
          "remindersPermission": "Allow Queue to access reminders for calendar sync support."
        }
      ],
      "expo-notifications",
      "@maplibre/maplibre-react-native",
      "@react-native-community/datetimepicker",
      "expo-asset"
    ],
    "extra": {
      "supportsRTL": true
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
