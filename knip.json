{
  "$schema": "https://unpkg.com/knip@latest/schema-jsonc.json",
  "entry": [
    "src/app/**/*.{ts,tsx}",
    "convex/**/*.ts",
    "scripts/**/*.{js,mjs,ts}",
    "src/components/maps/queue-map.tsx",
    "src/hooks/use-color-scheme.web.ts",
    "src/components/ui/icon-symbol.tsx",
    "babel.config.js",
    "metro.config.js"
  ],
  "project": [
    "src/app/**/*.{ts,tsx}",
    "src/components/**/*.{ts,tsx}",
    "src/constants/**/*.{ts,tsx}",
    "convex/**/*.ts",
    "src/hooks/**/*.{ts,tsx}",
    "src/i18n/**/*.{ts,tsx}",
    "src/lib/**/*.{ts,tsx}",
    "scripts/**/*.{js,mjs,ts}",
    "src/types/**/*.d.ts",
    "*.config.js",
    "!convex/_generated/**",
    "!src/constants/*.generated.ts",
    "!convex/*.generated.ts"
  ],
  "node": false,
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "ignoreBinaries": ["powershell", "python3"],
  "ignoreDependencies": ["babel-preset-expo", "expo-navigation-bar", "react-native-svg"],
  "ignore": [
    "src/components/maps/queue-map-apple-theme.ts",
    "src/components/maps/queue-map-zone-polygons.tsx",
    "src/components/maps/queue-map.native.tsx",
    "src/components/maps/queue-map.web.tsx",
    "src/components/maps/queue-map.native.helpers.ts",
    "src/components/maps/queue-map.web.helpers.ts",
    "src/components/ui/icon-symbol.ios.tsx"
  ]
}
