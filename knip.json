{
  "$schema": "https://unpkg.com/knip@latest/schema-jsonc.json",
  "entry": [
    "app/**/*.{ts,tsx}",
    "convex/**/*.ts",
    "scripts/**/*.{js,mjs,ts}",
    "components/maps/instructor-zones-map-component.native.tsx",
    "components/maps/instructor-zones-map-component.web.tsx",
    "components/maps/onboarding-location-map.native.tsx",
    "components/maps/onboarding-location-map.web.tsx",
    "components/ui/expressive/expressive-button.ios.tsx",
    "components/ui/expressive/expressive-button.android.tsx",
    "components/ui/expressive/expressive-chip.ios.tsx",
    "components/ui/expressive/expressive-chip.android.tsx",
    "components/ui/expressive/expressive-fab.ios.tsx",
    "components/ui/expressive/expressive-fab.android.tsx",
    "components/ui/expressive/expressive-surface.ios.tsx",
    "components/ui/expressive/expressive-surface.android.tsx",
    "components/ui/expressive/expressive-text-field.ios.tsx",
    "components/ui/expressive/expressive-text-field.android.tsx",
    "hooks/use-color-scheme.web.ts",
    "components/ui/icon-symbol.ios.tsx",
    "babel.config.js",
    "metro.config.js"
  ],
  "project": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "constants/**/*.{ts,tsx}",
    "convex/**/*.ts",
    "hooks/**/*.{ts,tsx}",
    "i18n/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx}",
    "scripts/**/*.{js,mjs,ts}",
    "types/**/*.d.ts",
    "*.config.js",
    "!convex/_generated/**",
    "!constants/*.generated.ts",
    "!convex/*.generated.ts"
  ],
  "node": false,
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "ignoreBinaries": [
    "powershell"
  ]
}
