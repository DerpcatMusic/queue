{
  "name": "queue",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/android/start-expo-windows.ps1",
    "android:device": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/android/start-device-windows.ps1",
    "android:device:release": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/android/install-release-device-windows.ps1",
    "android:doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/android/doctor-windows.ps1",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "knip": "knip --config knip.json --include files,dependencies,unlisted,binaries",
    "knip:full": "knip --config knip.json",
    "knip:production": "knip --config knip.json --production --include files,dependencies,unlisted,binaries",
    "typecheck": "tsc --noEmit",
    "perf:stats:report": "bunx convex run migrations:getJobApplicationStatsConsistencyReport '{\"sampleLimit\":20}'",
    "perf:stats:backfill": "bunx convex run migrations:backfillJobApplicationStats '{\"batchSize\":200}'",
    "perf:studio-ids:backfill": "bunx convex run migrations:backfillJobApplicationStudioIds '{\"batchSize\":200}'",
    "perf:stats:repair-jobs": "bunx convex run migrations:repairJobApplicationStatsForJobs '{\"jobIds\":[]}'",
    "convex:dev": "bunx convex dev",
    "convex:deploy": "bunx convex deploy",
    "plan:mvp": "cat ./docs/mvp-execution-plan.md",
    "seed:pikud-haoref": "node ./scripts/data/seed-pikud-haoref.mjs"
  },
  "dependencies": {
    "@auth/core": "0.37.0",
    "@convex-dev/auth": "^0.0.90",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@howljs/calendar-kit": "^2.5.6",
    "@maplibre/maplibre-react-native": "11.0.0-alpha.47",
    "@oslojs/crypto": "^1.0.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/native": "^7.1.8",
    "convex": "^1.32.0",
    "expo": "^55.0.0-preview.11",
    "expo-asset": "~55.0.6",
    "expo-auth-session": "~55.0.5",
    "expo-blur": "~55.0.7",
    "expo-build-properties": "~55.0.8",
    "expo-calendar": "~55.0.7",
    "expo-constants": "~55.0.6",
    "expo-device": "~55.0.8",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.6",
    "expo-haptics": "~55.0.7",
    "expo-image": "~55.0.4",
    "expo-linking": "~55.0.6",
    "expo-localization": "~55.0.7",
    "expo-location": "~55.1.1",
    "expo-notifications": "~55.0.9",
    "expo-router": "~55.0.0-preview.9",
    "expo-secure-store": "~55.0.7",
    "expo-splash-screen": "~55.0.8",
    "expo-status-bar": "~55.0.3",
    "expo-symbols": "~55.0.4",
    "expo-system-ui": "~55.0.8",
    "expo-updates": "~55.0.10",
    "expo-web-browser": "~55.0.8",
    "i18next": "^25.8.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "resend": "^6.9.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "^25.3.0",
    "@types/react": "~19.2.10",
    "knip": "^5.84.1",
    "typescript": "~5.9.2"
  },
  "resolutions": {
    "expo-asset": "~55.0.6",
    "expo-constants": "~55.0.6"
  },
  "overrides": {
    "hermes-compiler": "250829098.0.4"
  },
  "private": true
}
