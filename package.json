{
  "name": "queue",
  "main": "index.ts",
  "version": "1.0.0",
  "scripts": {
    "dev": "bun run ./scripts/dev/dev.ts",
    "postinstall": "node ./scripts/patches/patch-expo-devtools-keep-awake.mjs && node ./scripts/patches/patch-expo-router-react-navigation-dedupe.mjs",
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "node ./scripts/android/start-expo.mjs",
    "android:emulator": "node ./scripts/android/start-expo.mjs",
    "android:reset": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/android/reset-adb-windows.ps1",
    "android:device": "node ./scripts/android/start-device.mjs",
    "android:phone": "node ./scripts/android/start-device.mjs",
    "android:device:release": "node ./scripts/android/install-release-device.mjs",
    "android:doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/android/doctor-windows.ps1",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:no-hardcoded-styles": "node ./scripts/check-no-hardcoded-styles.mjs",
    "audit:knip": "knip --config knip.json --include files,dependencies,unlisted,binaries",
    "knip:full": "knip --config knip.json",
    "knip:production": "knip --config knip.json --production --include files,dependencies,unlisted,binaries",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "perf:stats:report": "bunx convex run migrations:getJobApplicationStatsConsistencyReport '{\"sampleLimit\":20}'",
    "perf:stats:backfill": "bunx convex run migrations:backfillJobApplicationStats '{\"batchSize\":200}'",
    "perf:studio-ids:backfill": "bunx convex run migrations:backfillJobApplicationStudioIds '{\"batchSize\":200}'",
    "perf:stats:repair-jobs": "bunx convex run migrations:repairJobApplicationStatsForJobs '{\"jobIds\":[]}'",
    "internal-access:grant": "node ./scripts/access/grant-internal-access.mjs",
    "convex:dev": "bunx convex dev",
    "convex:deploy": "bunx convex deploy",
    "plan:mvp": "cat ./docs/mvp-execution-plan.md",
    "seed:pikud-haoref": "node ./scripts/data/seed-pikud-haoref.mjs",
    "france:probe": "node ./scripts/france/probe-carte-pro.mjs",
    "seed:boundaries": "node ./scripts/data/import-boundary-catalog.mjs",
    "download:overture:london-boroughs": "python3 ./scripts/data/download-overture-london-boroughs.py",
    "build:london-boundary-tiles": "bash ./scripts/data/build-london-boundary-tiles.sh",
    "android:linux": "bash ./scripts/android/start-expo-linux.sh",
    "android:linux:phone": "bash ./scripts/android/start-device-linux.sh",
    "android:release:phone": "node ./scripts/android/install-release-device.mjs",
    "android:linux:release:phone": "bash ./scripts/android/install-release-device-linux.sh",
    "android:linux:rebuild": "rm -f android/.native-fingerprint && ANDROID_FORCE_REBUILD=1 bash ./scripts/android/start-expo-linux.sh",
    "android:rebuild": "node ./scripts/android/rebuild.mjs"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@convex-dev/auth": "^0.0.91",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/stripe": "^0.1.4",
    "@convex-dev/workflow": "^0.3.11",
    "@convex-dev/workpool": "^0.4.6",
    "@didit-protocol/sdk-react-native": "3.2.9",
    "@expo-google-fonts/barlow-condensed": "^0.4.1",
    "@expo-google-fonts/kanit": "^0.4.1",
    "@expo-google-fonts/lexend": "^0.4.1",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo-google-fonts/rubik": "^0.4.2",
    "@expo/ui": "~55.0.11",
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.2.9",
    "@oslojs/crypto": "^1.0.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-google-signin/google-signin": "16.1.2",
    "@react-navigation/native": "^7.1.33",
    "@rnmapbox/maps": "^10.3.0",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.4.18",
    "@stripe/stripe-react-native": "0.58.0",
    "convex": "^1.35.1",
    "expo": "~55.0.15",
    "expo-apple-authentication": "~55.0.13",
    "expo-auth-session": "~55.0.14",
    "expo-build-properties": "~55.0.13",
    "expo-calendar": "~55.0.14",
    "expo-constants": "~55.0.14",
    "expo-dev-client": "~55.0.27",
    "expo-device": "~55.0.15",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.16",
    "expo-font": "~55.0.6",
    "expo-glass-effect": "~55.0.10",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.8",
    "expo-image-manipulator": "~55.0.15",
    "expo-image-picker": "~55.0.18",
    "expo-linking": "~55.0.13",
    "expo-localization": "~55.0.13",
    "expo-location": "~55.1.8",
    "expo-navigation-bar": "~55.0.12",
    "expo-notifications": "~55.0.19",
    "expo-router": "~55.0.12",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.18",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.15",
    "expo-updates": "~55.0.20",
    "expo-web-browser": "~55.0.14",
    "geojson": "^0.5.0",
    "h3-js": "^4.4.0",
    "i18next": "26.0.6",
    "jose": "^6.2.2",
    "nanoid": "^5.1.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "17.0.4",
    "react-native": "0.83.4",
    "react-native-edge-to-edge": "^1.8.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-mmkv": "4.3.1",
    "react-native-nitro-modules": "0.35.4",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-unistyles": "^3.2.3",
    "react-native-web": "~0.21.2",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2",
    "resend": "6.12.2",
    "stripe": "^22.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@react-native-community/cli": "^20.1.3",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "@types/react": "~19.2.14",
    "babel-preset-expo": "~55.0.17",
    "eslint": "^10.2.1",
    "eslint-config-expo": "~55.0.0",
    "knip": "6.5.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.4"
  },
  "expo": {
    "install": {
      "exclude": [
        "expo-constants",
        "expo-file-system"
      ]
    }
  },
  "private": true,
  "trustedDependencies": [
    "@shopify/react-native-skia"
  ],
  "resolutions": {
    "lightningcss": "1.30.1"
  },
  "overrides": {
    "lightningcss": "1.30.1"
  }
}
