{
  "name": "queue",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "bun run ./scripts/dev/dev.ts",
    "postinstall": "node ./scripts/patches/patch-expo-devtools-keep-awake.mjs && node ./scripts/patches/patch-expo-router-react-navigation-dedupe.mjs && node ./scripts/patches/patch-didit-sdk-react-native-android-activity.mjs",
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "node ./scripts/android/start-expo.mjs",
    "android:emulator": "node ./scripts/android/start-expo.mjs",
    "android:reset": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/android/reset-adb-windows.ps1",
    "android:device": "node ./scripts/android/start-device.mjs",
    "android:phone": "node ./scripts/android/start-device.mjs",
    "android:device:release": "node ./scripts/android/install-release-device.mjs",
    "android:doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/android/doctor-windows.ps1",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "audit:knip": "knip --config knip.json --include files,dependencies,unlisted,binaries",
    "knip:full": "knip --config knip.json",
    "knip:production": "knip --config knip.json --production --include files,dependencies,unlisted,binaries",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "perf:stats:report": "bunx convex run migrations:getJobApplicationStatsConsistencyReport '{\"sampleLimit\":20}'",
    "perf:stats:backfill": "bunx convex run migrations:backfillJobApplicationStats '{\"batchSize\":200}'",
    "perf:studio-ids:backfill": "bunx convex run migrations:backfillJobApplicationStudioIds '{\"batchSize\":200}'",
    "perf:stats:repair-jobs": "bunx convex run migrations:repairJobApplicationStatsForJobs '{\"jobIds\":[]}'",
    "convex:dev": "bunx convex dev",
    "convex:deploy": "bunx convex deploy",
    "plan:mvp": "cat ./docs/mvp-execution-plan.md",
    "seed:pikud-haoref": "node ./scripts/data/seed-pikud-haoref.mjs",
    "android:linux": "bash ./scripts/android/start-expo-linux.sh",
    "android:linux:phone": "bash ./scripts/android/start-device-linux.sh",
    "android:release:phone": "node ./scripts/android/install-release-device.mjs",
    "android:linux:release:phone": "bash ./scripts/android/install-release-device-linux.sh"
  },
  "dependencies": {
    "@auth/core": "0.37.0",
    "@convex-dev/auth": "^0.0.91",
    "@didit-protocol/sdk-react-native": "^3.2.6",
    "@expo-google-fonts/barlow-condensed": "^0.4.1",
    "@expo-google-fonts/rubik": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@maplibre/maplibre-react-native": "11.0.0-alpha.47",
    "@oslojs/crypto": "^1.0.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-google-signin/google-signin": "16.1.2",
    "@react-navigation/native": "^7.1.33",
    "@shopify/flash-list": "2.0.2",
    "@tailwindcss/postcss": "^4.2.2",
    "clsx": "^2.1.1",
    "convex": "^1.34.0",
    "expo": "~55.0.8",
    "expo-auth-session": "~55.0.9",
    "expo-build-properties": "~55.0.10",
    "expo-calendar": "~55.0.10",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.18",
    "expo-device": "~55.0.10",
    "expo-file-system": "~55.0.11",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.8",
    "expo-haptics": "~55.0.9",
    "expo-image-manipulator": "~55.0.11",
    "expo-image-picker": "~55.0.13",
    "expo-linking": "~55.0.8",
    "expo-localization": "~55.0.9",
    "expo-location": "~55.1.4",
    "expo-navigation-bar": "~55.0.9",
    "expo-notifications": "~55.0.13",
    "expo-router": "~55.0.7",
    "expo-secure-store": "~55.0.9",
    "expo-splash-screen": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.10",
    "expo-updates": "~55.0.15",
    "expo-web-browser": "~55.0.10",
    "geojson": "^0.5.0",
    "i18next": "^25.9.0",
    "nativewind": "5.0.0-preview.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^16.5.8",
    "react-native": "0.83.2",
    "react-native-css": "0.0.0-nightly.5ce6396",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.7.2",
    "resend": "^6.9.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@react-native-community/cli": "^20.1.2",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@types/react": "~19.2.14",
    "babel-preset-expo": "~55.0.12",
    "knip": "^5.88.1",
    "typescript": "~5.9.3"
  },
  "expo": {
    "install": {
      "exclude": [
        "expo-constants",
        "expo-file-system"
      ]
    }
  },
  "private": true,
  "resolutions": {
    "lightningcss": "1.30.1"
  }
}
